{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "serve": "php artisan serve --port=8080 --host=127.0.0.1",
        "watch": "concurrently -n \"LARAVEL,VITE\" -c \"yellow,cyan\" \"php artisan serve --port=8080 --host=127.0.0.1\" \"vite\""
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^3.1",
        "tailwindcss": "^4.0.0",
        "vite": "^8.0.0"
    }
}
